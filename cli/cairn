#!/usr/bin/env bash
# =============================================================================
# cairn — Cairn CLI
#
# Usage:
#   cairn <command> [arguments]
#
# Commands:
#   init      Interactively initialize .cairn/ in the current project
#   status    Show three-layer summary and stale domain warnings
#   log       Record a history entry (interactive or flag mode)
#   sync      Generate an AI prompt to update a domain file from history
#   doctor    Run health checks on the .cairn/ structure (rules-only, no LLM)
#   stage     Manage staged history entries (review / accept / skip)
#   analyze   Analyze git history and generate staged candidates
#   reflect   Scan recent commits and emit staged update candidates
#   audit            Track migration residue (start / scan)
#   install-global   Inject Cairn Memory Protocol into global AI config files
#   version          Print version
#   help             Print this help message
#
# Installation:
#   Add the cli/ directory to your PATH (recommended), or symlink this script
#   to a directory on your PATH. Symlinks are supported via readlink resolution.
# =============================================================================

set -euo pipefail

# Resolve this script's real directory, following symlinks (BSD/GNU portable)
_cairn_src="${BASH_SOURCE[0]}"
while [ -L "$_cairn_src" ]; do
    _cairn_dir="$(cd -P "$(dirname "$_cairn_src")" && pwd)"
    _cairn_src="$(readlink "$_cairn_src")"
    [[ "$_cairn_src" != /* ]] && _cairn_src="$_cairn_dir/$_cairn_src"
done
CAIRN_CLI_DIR="$(cd -P "$(dirname "$_cairn_src")" && pwd)"
unset _cairn_src _cairn_dir

CAIRN_VERSION="0.0.10"

# =============================================================================
# Color support
# =============================================================================

if [ -t 1 ] && command -v tput >/dev/null 2>&1 && tput colors >/dev/null 2>&1 && [ "$(tput colors)" -ge 8 ]; then
    C_RESET="\033[0m"
    C_BOLD="\033[1m"
    C_GREEN="\033[0;32m"
    C_YELLOW="\033[0;33m"
    C_BLUE="\033[0;34m"
    C_CYAN="\033[0;36m"
    C_DIM="\033[2m"
    C_RED="\033[0;31m"
else
    C_RESET=""
    C_BOLD=""
    C_GREEN=""
    C_YELLOW=""
    C_BLUE=""
    C_CYAN=""
    C_DIM=""
    C_RED=""
fi

# ── language loader ──────────────────────────────────────────────────────────
_CAIRN_LANG_RAW="${CAIRN_LANG:-${LANG%%_*}}"
case "$_CAIRN_LANG_RAW" in
    zh*) source "$CAIRN_CLI_DIR/lang/zh.sh" ;;
    *)   source "$CAIRN_CLI_DIR/lang/en.sh" ;;
esac

# =============================================================================
# Shared utilities
# =============================================================================

# Find the project root containing .cairn/
# Walks up from PWD until it finds .cairn/ or reaches filesystem root.
# Prints the path and returns 0 on success, returns 1 if not found.
find_cairn_root() {
    local dir="$PWD"
    while [ "$dir" != "/" ]; do
        if [ -d "$dir/.cairn" ]; then
            echo "$dir"
            return 0
        fi
        dir="$(dirname "$dir")"
    done
    return 1
}

# Require .cairn/ to exist; print error and exit if not found.
require_cairn_root() {
    local root
    if ! root="$(find_cairn_root)"; then
        echo -e "${C_RED}error:${C_RESET} $(msg_err_no_cairn)" >&2
        echo -e "$(msg_err_run_init)" >&2
        exit 1
    fi
    echo "$root"
}

# Extract a specific field from output.md's ## stage section.
# Usage: parse_stage_field "phase" < output.md
parse_stage_field() {
    local field="$1"
    # Read between ## stage and the next ## section
    awk '/^## stage/{found=1; next} /^## [a-z]/{found=0} found && /^'"$field"':/{print; exit}' | \
        sed "s/^${field}: //"
}

# Extract locked domain names from output.md's ## hooks section.
# One domain name per line (e.g., "api-layer", "auth").
# Requires an arrow (→) before domains/ to avoid matching incidental
# references elsewhere in the file (e.g., no-go entries).
# Matches both formats:
#   New: → domains/<name>.md
#   Old: → read domains/<name>.md first  (backward-compatible)
# Usage: parse_domain_list < output.md
parse_domain_list() {
    grep -oE '→[[:space:]]+(read[[:space:]]+)?domains/[a-z][a-z0-9-]+\.md' | \
        grep -oE 'domains/[a-z][a-z0-9-]+\.md' | \
        sed 's|domains/||;s|\.md||'
}

# Extract a frontmatter field from a domain file (--- delimited YAML).
# Usage: parse_domain_field "updated" < domains/api-layer.md
parse_domain_field() {
    local field="$1"
    # Read lines between first and second --- delimiters
    awk '/^---$/{count++; next} count==1{print}' | \
        grep "^${field}:" | head -1 | sed "s/^${field}: //"
}

# Extract a field from a history file (bare key-value, no --- delimiters).
# Only reads first-line value (single-line fields like domain, type, dates).
# Usage: parse_history_field "domain" < history/2023-09_trpc.md
parse_history_field() {
    local field="$1"
    grep "^${field}:" | head -1 | sed "s/^${field}: //"
}

# Check if a domain is stale relative to its history entries.
# Outputs: "stale|LATEST_HIST|DOMAIN_UPDATED|NEW_ENTRIES"
#          "fresh|LATEST_HIST|DOMAIN_UPDATED|0"
#          "no-history||DOMAIN_UPDATED|0"
#          "no-domain|||0"
# Usage: compute_domain_stale <cairn_dir> <domain_name>
compute_domain_stale() {
    local cairn_dir="$1"
    local domain="$2"
    local domain_file="$cairn_dir/domains/${domain}.md"
    local history_dir="$cairn_dir/history"

    if [ ! -f "$domain_file" ]; then
        echo "no-domain|||0"
        return 0
    fi

    local domain_updated=""
    domain_updated="$(awk '/^---$/{count++; next} count==1{print}' "$domain_file" \
        | grep "^updated:" | head -1 | sed 's/^updated: //' | tr -d '[:space:]' || true)"

    if [ -z "$domain_updated" ]; then
        echo "no-domain|||0"
        return 0
    fi

    local latest_hist=""
    local new_entries=0

    if [ -d "$history_dir" ]; then
        while IFS= read -r hist_file; do
            local hbase
            hbase="$(basename "$hist_file")"
            [ "$hbase" = "_TEMPLATE.md" ] && continue

            local hdomain hrdate
            hdomain="$(grep "^domain:" "$hist_file" 2>/dev/null | head -1 \
                | sed 's/^domain: //' | tr -d '[:space:]' || true)"
            hrdate="$(grep "^recorded_date:" "$hist_file" 2>/dev/null | head -1 \
                | sed 's/^recorded_date: //' | tr -d '[:space:]' || true)"

            [ "$hdomain" = "$domain" ] || continue
            [ -n "$hrdate" ] || continue

            if [ -z "$latest_hist" ] || [[ "$hrdate" > "$latest_hist" ]]; then
                latest_hist="$hrdate"
            fi
            [[ "$hrdate" > "$domain_updated" ]] && new_entries=$(( new_entries + 1 ))
        done < <(find "$history_dir" -maxdepth 1 -name "*.md" -type f 2>/dev/null | sort)
    fi

    if [ -z "$latest_hist" ]; then
        echo "no-history||${domain_updated}|0"
    elif [[ "$latest_hist" > "$domain_updated" ]]; then
        echo "stale|${latest_hist}|${domain_updated}|${new_entries}"
    else
        echo "fresh|${latest_hist}|${domain_updated}|0"
    fi
}

# Approximate token count for a file (chars / 4 heuristic, GPT-style).
# Outputs an integer. Caller should display with a ≈ prefix.
# Usage: count_tokens_approx <file>
count_tokens_approx() {
    local file="$1"
    local chars
    chars="$(wc -c < "$file" | tr -d '[:space:]')"
    echo $(( chars / 4 ))
}

# List staged entry files in a .cairn/ directory, one per line (sorted).
# Silently outputs nothing if staged/ does not exist or has no .md files.
# Usage: find_staged_files <cairn_dir>
find_staged_files() {
    local cairn_dir="$1"
    local staged_dir="$cairn_dir/staged"
    if [ ! -d "$staged_dir" ]; then
        return 0
    fi
    find "$staged_dir" -maxdepth 1 -name "*.md" -type f 2>/dev/null | sort
}

# -----------------------------------------------------------------------------
# Parse hooks[] from a single domain frontmatter (YAML flow-style array).
# Outputs one keyword per line (original case).
# Usage: extract_domain_hooks <domain_file>
# -----------------------------------------------------------------------------
extract_domain_hooks() {
    local domain_file="$1"
    awk '/^---$/{count++; next} count==1{print} count==2{exit}' "$domain_file" \
        | grep '^hooks:' \
        | sed 's/hooks: //; s/\[//; s/\]//; s/"//g; s/,/ /g' \
        | tr ' ' '\n' \
        | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' \
        | grep -E '^[^ ]' \
        | sort -u
}

# =============================================================================
# Help text
# =============================================================================

show_help() {
    echo ""
    echo -e "${C_BOLD}$(msg_help_tagline)${C_RESET}"
    echo ""
    echo -e "${C_BOLD}$(msg_help_usage_label)${C_RESET}"
    echo -e "$(msg_help_usage_line)"
    echo ""
    echo -e "${C_BOLD}$(msg_help_commands_label)${C_RESET}"
    echo -e "  ${C_CYAN}init${C_RESET}     $(msg_help_cmd_init)"
    echo -e "  ${C_CYAN}status${C_RESET}   $(msg_help_cmd_status)"
    echo -e "  ${C_CYAN}log${C_RESET}      $(msg_help_cmd_log)"
    echo -e "  ${C_CYAN}sync${C_RESET}     $(msg_help_cmd_sync)"
    echo -e "  ${C_CYAN}doctor${C_RESET}   $(msg_help_cmd_doctor)"
    echo -e "  ${C_CYAN}stage${C_RESET}    $(msg_help_cmd_stage)"
    echo -e "  ${C_CYAN}analyze${C_RESET}  $(msg_help_cmd_analyze)"
    echo -e "  ${C_CYAN}reflect${C_RESET}  $(msg_help_cmd_reflect)"
    echo -e "  ${C_CYAN}audit${C_RESET}           $(msg_help_cmd_audit)"
    echo -e "  ${C_CYAN}install-global${C_RESET}  Inject Cairn Memory Protocol into global AI config files"
    echo -e "  ${C_CYAN}version${C_RESET}         $(msg_help_cmd_version)"
    echo -e "  ${C_CYAN}help${C_RESET}     $(msg_help_cmd_help)"
    echo ""
    echo -e "${C_BOLD}$(msg_help_examples_label)${C_RESET}"
    echo -e "  cairn init"
    echo -e "  cairn status"
    echo -e "  cairn log --type rejection --domain api-layer --summary \"Rejected GraphQL\""
    echo -e "  cairn log --quick"
    echo -e "  cairn sync api-layer"
    echo -e "  cairn doctor"
    echo -e "  cairn stage review"
    echo ""
    echo -e "${C_DIM}$(msg_help_spec_hint)${C_RESET}"
    echo ""
}

# =============================================================================
# Subcommand dispatch
# =============================================================================

CMD="${1:-}"
shift 2>/dev/null || true

case "$CMD" in
    init)
        source "$CAIRN_CLI_DIR/cmd/init.sh"
        cmd_init "$@"
        ;;
    status)
        source "$CAIRN_CLI_DIR/cmd/status.sh"
        cmd_status "$@"
        ;;
    log)
        source "$CAIRN_CLI_DIR/cmd/log.sh"
        cmd_log "$@"
        ;;
    sync)
        source "$CAIRN_CLI_DIR/cmd/sync.sh"
        cmd_sync "$@"
        ;;
    doctor)
        source "$CAIRN_CLI_DIR/cmd/doctor.sh"
        cmd_doctor "$@"
        ;;
    stage)
        source "$CAIRN_CLI_DIR/cmd/stage.sh"
        cmd_stage "$@"
        ;;
    analyze)
        source "$CAIRN_CLI_DIR/cmd/analyze.sh"
        cmd_analyze "$@"
        ;;
    reflect)
        source "$CAIRN_CLI_DIR/cmd/reflect.sh"
        cmd_reflect "$@"
        ;;
    audit)
        source "$CAIRN_CLI_DIR/cmd/audit.sh"
        cmd_audit "$@"
        ;;
    install-global)
        source "$CAIRN_CLI_DIR/cmd/install-global.sh"
        cmd_install_global "$@"
        ;;
    version|--version|-v)
        echo "cairn $CAIRN_VERSION"
        ;;
    help|--help|-h|"")
        show_help
        ;;
    *)
        echo -e "${C_RED}error:${C_RESET} $(msg_err_unknown_cmd "$CMD")" >&2
        echo -e "$(msg_err_run_help)" >&2
        exit 1
        ;;
esac

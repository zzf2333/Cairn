{
    "name": "cairn-rt",
    "version": "0.4.12",
    "description": "Cairn — cognitive runtime for AI-native engineering",
    "type": "module",
    "license": "MIT",
    "author": "Cairn Contributors",
    "repository": {
        "type": "git",
        "url": "https://github.com/zzf2333/Cairn.git",
        "directory": "cli"
    },
    "homepage": "https://github.com/zzf2333/Cairn/tree/main/cli",
    "bugs": {
        "url": "https://github.com/zzf2333/Cairn/issues"
    },
    "keywords": [
        "cairn",
        "ai",
        "cognition",
        "engineering-memory",
        "skill-protocol"
    ],
    "files": [
        "dist/**/*.js",
        "dist/**/*.d.ts",
        "README.md"
    ],
    "publishConfig": {
        "access": "public"
    },
    "bin": {
        "cairn": "dist/cli/index.js"
    },
    "scripts": {
        "build": "tsc",
        "postinstall": "node dist/postinstall.js 2>/dev/null || true",
        "dev": "tsx src/cli/index.ts",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "bench": "vitest run tests/performance --reporter=verbose",
        "scenarios": "npm run build && tsx tests/scenarios/runner/index.ts",
        "scenarios:cc": "npm run build && tsx tests/scenarios/runner/index.ts --platform claude-code",
        "scenarios:codex": "npm run build && tsx tests/scenarios/runner/index.ts --platform codex",
        "smoke": "npm run build && tsx tests/scenarios/runner/smoke-all.ts",
        "smoke:lifecycle": "npm run build && tsx tests/scenarios/runner/smoke-lifecycle.ts"
    },
    "dependencies": {
        "simple-git": "^3.27.0",
        "yaml": "^2.7.0",
        "zod": "^3.25.0"
    },
    "devDependencies": {
        "@anthropic-ai/sdk": "^0.96.0",
        "@types/node": "^22.0.0",
        "@vitest/coverage-v8": "^3.2.6",
        "openai": "^6.38.0",
        "tsx": "^4.19.0",
        "typescript": "^5.8.0",
        "vitest": "^3.2.6"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}
